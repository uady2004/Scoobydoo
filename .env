# ──────────────────────────────────────────────────────────────────────────────
# TikTok Clone — local dev environment variables
# These override the defaults in docker-compose.yml.
# DO NOT commit real secrets to version control.
# ──────────────────────────────────────────────────────────────────────────────

# JWT secrets (shared across auth-service, wallet-service, ecommerce-service)
JWT_SECRET=tiktok-dev-secret-change-in-production-2024
JWT_REFRESH_SECRET=tiktok-dev-refresh-secret-change-in-production-2024

# Admin service JWT secret
ADMIN_JWT_SECRET=tiktok-admin-secret-change-in-production-2024

# API gateway asymmetric JWT public key (leave empty in dev — gateway will warn but start)
JWT_PUBLIC_KEY_PEM=

# ── Notification service credentials ──────────────────────────────────────────
# These are placeholders. Replace with real values to enable push/email/SMS.
# The service will start with placeholders but notifications won't be delivered.

FIREBASE_PROJECT_ID=placeholder-project
FIREBASE_CREDENTIALS_JSON=placeholder-credentials

SENDGRID_API_KEY=SG.placeholder
SENDGRID_FROM_EMAIL=noreply@example.com

TWILIO_ACCOUNT_SID=ACplaceholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_FROM_NUMBER=+10000000000
